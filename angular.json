{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "732d4bf7-d41a-403b-a5bf-6369c446b5d7"
  },
  "newProjectRoot": "projects",
  "projects": {
    "ruby-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/ruby-frontend-app",
      "sourceRoot": "projects/ruby-frontend-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/ruby-frontend-app/src/main.ts",
            "tsConfig": "projects/ruby-frontend-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ruby-frontend-app/public"
              },
              {
                "glob": "**/*",
                "input": "projects/ruby-frontend-app/src/assets",
                "output": "assets"
              }
            ],
            "styles": ["projects/ruby-frontend-app/src/styles.scss"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "32kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ruby-frontend:build:production"
            },
            "development": {
              "buildTarget": "ruby-frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ruby-frontend-app/tsconfig.spec.json"
          }
        }
      }
    },
    "lib-ruby-core": {
      "projectType": "library",
      "root": "projects/lib-ruby-core",
      "sourceRoot": "projects/lib-ruby-core/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/lib-ruby-core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/lib-ruby-core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/lib-ruby-core/tsconfig.spec.json"
          }
        }
      }
    },
    "lib-ruby-core-ui": {
      "projectType": "library",
      "root": "projects/lib-ruby-core-ui",
      "sourceRoot": "projects/lib-ruby-core-ui/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/lib-ruby-core-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/lib-ruby-core-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/lib-ruby-core-ui/tsconfig.spec.json"
          }
        }
      }
    },
    "lib-ruby-sdks": {
      "projectType": "library",
      "root": "projects/lib-ruby-sdks",
      "sourceRoot": "projects/lib-ruby-sdks/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/lib-ruby-sdks/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/lib-ruby-sdks/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/lib-ruby-sdks/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
